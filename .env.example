# Core runtime
SSE_ENV=dev
SSE_LOG_LEVEL=INFO
SSE_STORAGE_ROOT=./data
SSE_SQLITE_PATH=./data/metadata.db

# Feature toggles
SSE_ENABLE_ZERODHA=false
SSE_ENABLE_BREEZE=false
SSE_ENABLE_NLP=true
SSE_ENABLE_LLM_EXTRACTION=false

# Runtime data providers (deployment defaults use free/public sources)
SSE_MARKET_PROVIDER=nse_http
SSE_MARKET_UNIVERSE=RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,SBIN,LT,ITC,HINDUNILVR,BHARTIARTL
SSE_NEWS_PROVIDER=free_rss
SSE_FILINGS_PROVIDER=exchange_announcements
SSE_TRANSCRIPTS_PROVIDER=none

# LLM provider controls
SSE_LLM_PROVIDER=heuristic
SSE_LLM_MODEL=heuristic-finance-v1
SSE_LLM_BASE_URL=https://api.openai.com
SSE_LLM_API_KEY_ENV=OPENAI_API_KEY
SSE_LLM_TIMEOUT_SECONDS=30
SSE_LLM_MIN_CONFIDENCE=0.55
SSE_LLM_FALLBACK_TO_RULES=true
SSE_LLM_ENABLE_MANAGEMENT_TONE=true
SSE_LLM_AUDIT_LOW_CONFIDENCE=true
SSE_LLM_AUDIT_PATH=./data

# Define the provider key referenced by SSE_LLM_API_KEY_ENV when using real LLMs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional API credentials
SSE_ZERODHA_API_KEY=
SSE_ZERODHA_API_SECRET=
SSE_ZERODHA_ACCESS_TOKEN=

SSE_BREEZE_API_KEY=
SSE_BREEZE_API_SECRET=
SSE_BREEZE_SESSION_TOKEN=
